# Copy this file to `.env` and fill in real DEV values. `.env` is git-ignored.
# (api/.env holds secrets and must NEVER be committed.)

# Postgres connection (Supabase → Connect → Session pooler → URI form).
# IMPORTANT: change the scheme from `postgresql://` to `postgresql+asyncpg://`
# so SQLAlchemy uses the async driver.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres

# Supabase project URL (Settings → Data API → Project URL).
# The JWKS endpoint is derived from this: <SUPABASE_URL>/auth/v1/.well-known/jwks.json
SUPABASE_URL=https://YOUR-REF.supabase.co

# Audience claim our tokens must carry (Supabase default is "authenticated").
SUPABASE_JWT_AUD=authenticated

# Browser origins allowed to call this API (comma-separated). Local Next.js dev:
CORS_ORIGINS=http://localhost:3000
